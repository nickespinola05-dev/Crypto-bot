# ============================================================
# Hybrid Grid + Momentum Switch - Crypto Bot
# Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit .env to git!
# ============================================================

# --- Coinbase Advanced Trade API Credentials ---
# Get these from: https://portal.cdp.coinbase.com/access/api
# Format for API key:  organizations/{org_id}/apiKeys/{key_id}
# Format for secret:   The full EC private key string (keep the BEGIN/END lines)
COINBASE_API_KEY=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END EC PRIVATE KEY-----\n

# --- Trading Settings ---
# Which coin pairs to trade (comma-separated)
TRADING_PAIRS=DOGE-USD,SHIB-USD,PEPE-USD
# Maximum USD to allocate per trading pair
MAX_POSITION_SIZE_USD=100.0
# Are we in paper/test mode? (true = no real orders)
PAPER_TRADING=true

# --- Risk Management ---
# Max % of total capital allowed in one coin (e.g. 25 = 25%)
MAX_POSITION_PCT=25.0
# Max % daily loss before bot stops trading (e.g. 5 = -5% from start of day)
DAILY_LOSS_LIMIT_PCT=5.0
# Max drawdown % from peak equity before bot shuts down (e.g. 15 = -15%)
MAX_DRAWDOWN_PCT=15.0

# --- Telegram Alerts ---
# Get a bot token from @BotFather on Telegram (free)
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to true to enable Telegram alerts
ENABLE_TELEGRAM_ALERTS=false

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
